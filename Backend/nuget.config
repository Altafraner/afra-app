<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="github-altafraner" value="https://nuget.pkg.github.com/altafraner/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github-altafraner">
      <package pattern="Altafraner.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
